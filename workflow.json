        "message": "=<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; line-height: 1.5; color: #111827;\">\n  <h2 style=\"margin: 0 0 12px; font-size: 18px; font-weight: 700;\">\n    Airtable Update Failed\n  </h2>\n\n  <p style=\"margin: 0 0 12px;\">\n    The assignment status for the post titled\n    <strong>{{ $('Webhook').item.json.body.entry.title }}</strong>\n    could not be updated in Airtable.\n  </p>\n\n  <div style=\"margin: 16px 0; padding: 12px 14px; background: #FEF3C7; border: 1px solid #F59E0B; border-radius: 8px;\">\n    <p style=\"margin: 0; font-weight: 600;\">What happened?</p>\n    <p style=\"margin: 6px 0 0;\">\n      The record could not be fetched from Airtable because no matching title was found.\n    </p>\n  </div>\n\n  <div style=\"margin: 16px 0; padding: 12px 14px; background: #EFF6FF; border: 1px solid #60A5FA; border-radius: 8px;\">\n    <p style=\"margin: 0; font-weight: 600;\">How to fix it</p>\n    <p style=\"margin: 6px 0 0;\">\n      Make sure the <strong>Entry Title</strong> in Strapi exactly matches the title in Airtable (including spelling, spacing, and punctuation).\n    </p>\n  </div>\n</div>",
